TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
# Slack incoming webhook for sendSlackMessage.
# Mint at: api.slack.com/apps > (your app) > Incoming Webhooks >
# Add New Webhook to Workspace > select #execution-feed > Allow.
# The webhook is bound to that channel; paste the
# https://hooks.slack.com/services/... URL below. Leave blank to no-op.
SLACK_WEBHOOK_URL=
